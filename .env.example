# Copy this file to .env.local and fill in your values

# Anthropic API Key - Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database path (relative to project root)
DATABASE_PATH=./data/agents.db

# ── Microsoft SSO (Azure AD / Entra ID) ──────────────────────────────────────
# Required for SSO to work — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_random_secret_here

# Base URL of this app (used for OAuth callback)
NEXTAUTH_URL=http://localhost:9001

# Set to 1 to enforce SSO login for all pages (requires above credentials saved in Settings)
# MS_SSO_ENABLED=1

# Optional: override DB-stored Azure AD credentials via env vars
# AZURE_AD_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_AD_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_AD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
